{
  "version": "2026-03-19-001",
  "views": {
    "account": {
      "html": "<div class='account-view'><div class='sec-head'><div class='sec-title'>Account settings</div></div><div class='card'><div class='card-title'>Profile</div><div class='card-desc'>Manage your personal information.</div><div class='form-grid'><div class='fg'><label>Full name</label><input type='text' id='acct-name' placeholder='Your name'></div><div class='fg'><label>Email</label><input type='email' id='acct-email' readonly style='opacity:.6'></div></div><div class='form-actions'><button class='btn primary' onclick='saveProfile()'>Save changes</button></div></div><div class='card'><div class='card-title'>Passkeys</div><div class='card-desc'>Manage your registered devices for passwordless sign-in.</div><div id='passkey-list'></div><div class='form-actions'><button class='btn primary' onclick='registerPasskey()'><svg viewBox='0 0 24 24' width='14' height='14' stroke='currentColor' fill='none' stroke-width='1.5'><path d='M12 5v14M5 12h14'/></svg> Register new passkey</button></div></div><div class='card'><div class='card-title'>Active sessions</div><div class='card-desc'>Devices currently signed in to your account.</div><div id='session-list'></div></div></div>",
      "css": ".account-view .card{margin-bottom:16px}.account-view .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}.account-view .fg label{display:block;font-size:13px;color:var(--t2);margin-bottom:5px}.account-view .fg input{width:100%;padding:10px 14px;font-family:var(--font);font-size:14px;color:var(--t1);background:var(--bg4);border:1px solid var(--bdr);border-radius:8px;outline:0;transition:all .2s}.account-view .fg input:focus{border-color:var(--acc);box-shadow:0 0 0 3px var(--acc-dim)}.account-view .form-actions{display:flex;gap:8px;margin-top:14px}",
      "js": "function initAccount(container, api, user) { container.querySelector('#acct-name').value = user.name || ''; container.querySelector('#acct-email').value = user.email || ''; }"
    },
    "billing": {
      "html": "<div class='billing-view'><div class='sec-head'><div class='sec-title'>Billing</div></div><div class='card'><div class='card-title'>Current plan</div><div id='billing-plan-info'><div class='plan-tier'>Free</div><div class='plan-desc'>Upgrade to start using dashboards.</div></div><div class='form-actions'><button class='btn primary' onclick='managePlan()'>Manage subscription</button></div></div><div class='card'><div class='card-title'>Choose a plan</div><div class='card-desc'>Select a tier to get started with XRay dashboards.</div><div id='stripe-pricing-container'></div></div></div>",
      "css": ".billing-view .card{margin-bottom:16px}.billing-view .plan-tier{font-size:24px;font-weight:600;margin-bottom:4px}.billing-view .plan-desc{font-size:14px;color:var(--t2)}",
      "js": "function initBilling(container, api, user) { /* Stripe pricing table loaded dynamically */ }"
    },
    "team": {
      "html": "<div class='team-view'><div class='sec-head'><div class='sec-title'>Team members</div><div class='sec-actions'><button class='btn primary' onclick='openInviteModal()'><svg viewBox='0 0 24 24' width='14' height='14' stroke='currentColor' fill='none' stroke-width='1.5'><path d='M12 5v14M5 12h14'/></svg> Invite member</button></div></div><div class='tbl-wrap'><table class='tbl'><thead><tr><th>Member</th><th>Role</th><th>Status</th><th>Last active</th><th></th></tr></thead><tbody id='team-tbody'></tbody></table></div><div class='sec-head' style='margin-top:24px'><div class='sec-title'>Pending invitations</div></div><div id='invite-list'></div></div>",
      "css": ".team-view .tbl-wrap{margin-bottom:0}",
      "js": "function initTeam(container, api, user) { /* Loads team data from API */ }"
    },
    "admin_builder": {
      "html": "<div class='builder-view'><div class='sec-title' style='margin-bottom:16px'>Dashboard builder</div><div class='card'><div class='card-title'>Create or edit a dashboard</div><div class='card-desc'>Upload HTML, CSS, and JavaScript for a dashboard view. Configure data sources and access.</div><div class='form-grid c1'><div class='fg'><label>Tenant</label><select id='build-tenant'></select></div><div class='fg'><label>Dashboard name</label><input type='text' id='build-name' placeholder='e.g. Revenue overview'></div><div class='fg'><label>Description</label><input type='text' id='build-desc' placeholder='Brief description'></div><div class='fg full'><label>HTML</label><textarea id='build-html' style='min-height:160px;font-family:var(--mono);font-size:13px' placeholder='Dashboard HTML...'></textarea></div><div class='fg full'><label>CSS</label><textarea id='build-css' style='min-height:100px;font-family:var(--mono);font-size:13px' placeholder='Dashboard CSS...'></textarea></div><div class='fg full'><label>JavaScript</label><textarea id='build-js' style='min-height:100px;font-family:var(--mono);font-size:13px' placeholder='function initDashboard(container, api, sources) { ... }'></textarea></div></div><div class='form-actions'><button class='btn primary'>Save dashboard</button><button class='btn'>Preview</button></div></div></div>",
      "css": ".builder-view .form-grid.c1{grid-template-columns:1fr}.builder-view textarea{resize:vertical}",
      "js": "function initBuilder(container, api, user) { /* Load tenants for dropdown */ }"
    },
    "admin_settings": {
      "html": "<div class='settings-view'><div class='sec-title' style='margin-bottom:16px'>Platform settings</div><div class='card'><div class='card-title'>SMTP configuration</div><div class='card-desc'>Configure outbound email for magic links, invitations, and notifications.</div><div class='form-grid c3'><div class='fg'><label>SMTP host</label><input type='text' id='set-smtp-host' placeholder='smtp.example.com'></div><div class='fg'><label>Port</label><input type='text' id='set-smtp-port' placeholder='587'></div><div class='fg'><label>Encryption</label><select id='set-smtp-secure'><option value='true'>STARTTLS</option><option value='false'>None</option></select></div><div class='fg'><label>Username</label><input type='text' id='set-smtp-user' placeholder='SMTP username'></div><div class='fg'><label>Password</label><input type='password' id='set-smtp-pass' placeholder='SMTP password'></div><div class='fg'><label>From address</label><input type='email' id='set-smtp-from' placeholder='noreply@domain.com'></div></div><div class='form-actions'><button class='btn primary' onclick='saveSmtp()'>Save SMTP</button><button class='btn' onclick='testSmtp()'>Send test email</button></div></div><div class='card'><div class='card-title'>Platform</div><div class='form-grid'><div class='fg'><label>Platform name</label><input type='text' id='set-name' placeholder='XRay BI'></div><div class='fg'><label>Support email</label><input type='email' id='set-support' placeholder='support@domain.com'></div><div class='fg'><label>Domain</label><input type='text' id='set-domain' placeholder='app.yourdomain.com'></div></div><div class='form-actions'><button class='btn primary' onclick='savePlatform()'>Save platform settings</button></div></div><div class='card'><div class='card-title'>Stripe integration</div><div class='card-desc'>Configure Stripe for billing. Keys are stored encrypted.</div><div class='form-grid'><div class='fg'><label>Publishable key</label><input type='text' id='set-stripe-pk' placeholder='pk_live_...'></div><div class='fg'><label>Pricing table ID</label><input type='text' id='set-stripe-table' placeholder='prctbl_...'></div></div><div class='form-actions'><button class='btn primary' onclick='saveStripe()'>Save Stripe config</button><a href='https://dashboard.stripe.com' target='_blank' class='btn'>Open Stripe Dashboard &rarr;</a></div></div></div>",
      "css": ".settings-view .card{margin-bottom:16px}.settings-view .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}.settings-view .form-grid.c3{grid-template-columns:1fr 1fr 1fr}",
      "js": "function initSettings(container, api, user) { /* Load current settings */ }"
    }
  },
  "nav": [
