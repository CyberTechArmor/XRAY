{
  "name": "xray-server",
  "version": "1.0.0",
  "description": "XRay BI Platform Server",
  "main": "dist/index.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed.ts",
    "backfill:encrypt-credentials": "node dist/scripts/backfill-encrypt-credentials.js",
    "backfill:encrypt-credentials:dev": "tsx src/scripts/backfill-encrypt-credentials.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@simplewebauthn/server": "^10.0.0",
    "adm-zip": "^0.5.17",
    "archiver": "^7.0.1",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.7",
    "otplib": "^12.0.1",
    "pg": "^8.13.0",
    "qrcode": "^1.5.4",
    "stripe": "^14.0.0",
    "uuid": "^9.0.0",
    "web-push": "^3.6.7",
    "ws": "^8.20.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^7.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^9.0.8",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
