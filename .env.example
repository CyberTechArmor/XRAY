# ============================================
# XRay Platform — Environment Configuration
# ============================================
# Copy to .env and fill in your values
# NEVER commit .env to version control

# Server
APP_PORT=3000
JWT_SECRET=change-me-to-a-random-64-char-string
ENCRYPTION_KEY=change-me-to-a-random-32-byte-hex-string

# Database
DB_HOST=postgres          # 'postgres' for Dockerized, or external host
DB_NAME=xray
DB_USER=xray
DB_PASSWORD=change-me-strong-password

# WebAuthn (CRITICAL: RP_ID cannot change after passkeys are registered)
RP_NAME=XRay BI
RP_ID=localhost
ORIGIN=http://localhost:3000

# Stripe (webhook secret must be server-side; other keys configured via admin UI)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Web Push (VAPID) — MEET call mobile notifications
# Generate with: cd server && npx web-push generate-vapid-keys
# Auto-generated by install.sh / update.sh
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Fallback SMTP (used only before admin UI configuration)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
